{
  "name": "terminal-session-manager",
  "version": "0.1.0",
  "private": true,
  "description": "PWA + WSS Terminal Session Manager - resilient PTY sessions over WebSocket",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @tsm/server dev\" \"pnpm --filter @tsm/client dev\"",
    "build": "pnpm --filter @tsm/server build && pnpm --filter @tsm/client build",
    "build:server": "pnpm --filter @tsm/server build",
    "build:client": "pnpm --filter @tsm/client build",
    "start": "pnpm --filter @tsm/server start",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "node-pty"]
  }
}
